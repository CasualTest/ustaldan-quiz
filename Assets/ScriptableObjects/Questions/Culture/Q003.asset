  category: {fileID: 11400000, guid: 6cb06c8a26a77c44384176150f88cef8, type: 2}
  questionText: "\u041A\u0442\u043E \u0438\u0437 \u0433\u0435\u0440\u043E\u0435\u0432
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u0422\u0430\u043D\u0434\u0435?"
  questionTextSah: "\u0422\u0430\u043D\u0434\u0430\u0495\u0430 \u0445\u0430\u043D\u043D\u044B\u043A
    \u0413\u0435\u0440\u043E\u0439 \u0442\u04E9\u0440\u04E9\u04E9\u0431\u04AF\u0442\u044D\u0439?"
  questionImage: {fileID: 0}
  answers:
  - "\u0412. \u041B\u043E\u043D\u0433\u0438\u043D\u043E\u0432"
  - "\u0418. \u041A\u0443\u043B\u044C\u0431\u0435\u0440\u0442\u0438\u043D\u043E\u0432"
  - "\u041C. \u0421\u0442\u0440\u0435\u043A\u0430\u043B\u043E\u0432\u0441\u043A\u0438\u0439"
  - "\u0413. \u041F\u043E\u043F\u043E\u0432"
  difficulty: 1
  factAfterRu: "\u0413\u0435\u0440\u043E\u0439 \u0421\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u0421\u043E\u044E\u0437\u0430 \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440
    \u041B\u043E\u043D\u0433\u0438\u043D\u043E\u0432 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0441\u0435\u043B\u0435 \u0422\u0430\u043D\u0434\u0430."
  factAfterSah: "\u0421\u044D\u0431\u0438\u044D\u0441\u043A\u044D\u0439 \u0441\u043E\u044E\u0437
    \u0433\u0435\u0440\u043E\u0439\u0430 \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440
    \u041B\u043E\u043D\u0433\u0438\u043D\u043E\u0432 \u0422\u0430\u043D\u0434\u04305\u0430
    \u0442\u043E\u0440\u043E\u043E\u0431\u0443\u0442\u044D."
